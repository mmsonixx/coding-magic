        } else {
            btnPvP.classList.add('ttt-active');
            btnPvE.classList.remove('ttt-active');
        }
        resetTicTacToe();
    }
    tttBoard.addEventListener('click', handleCellInteraction);
    tttResetBtn.addEventListener('click', resetTicTacToe);
