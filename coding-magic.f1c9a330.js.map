        ];
        gameActive = true;
        if (isBotMode) tttStatus.textContent = "\u0412\u0430\u0448 \u0445\u0456\u0434 (\u0425\u0440\u0435\u0441\u0442\u0438\u043A)";
        else tttStatus.textContent = "\u0425\u043E\u0434\u0438\u0442\u044C \u0413\u0440\u0430\u0432\u0435\u0446\u044C 1 (\u0425\u0440\u0435\u0441\u0442\u0438\u043A)";
        tttCells.forEach((cell)=>cell.innerHTML = '');
